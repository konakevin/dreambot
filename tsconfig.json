{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "supabase/functions/**",
    "__tests__/lib/selfInsertDetector.test.ts",
    "__tests__/lib/renderEntity.test.ts",
    "__tests__/lib/sanitize.test.ts",
    "__tests__/lib/modelPicker.test.ts",
    "__tests__/lib/promptCompiler.test.ts"
  ]
}